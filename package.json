{
  "name": "nodiary",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "electron": "electron electron/main.cjs",
    "electron:dev": "node scripts/dev-electron.mjs",
    "electron:pack": "electron-builder --dir",
    "electron:dist": "electron-builder",
    "build": "next build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:init": "tsx prisma/bootstrap-sqlite.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "tsx prisma/bootstrap-sqlite.ts",
    "db:studio": "prisma studio"
  },
  "build": {
    "appId": "com.nodiary.desktop",
    "productName": "Nodiary",
    "files": [
      "electron/**/*",
      "scripts/**/*",
      ".next/**/*",
      "next.config.ts",
      "package.json",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    }
  },
  "dependencies": {
    "@fontsource/noto-sans-kr": "^5.2.8",
    "@prisma/client": "^6.19.3",
    "@tiptap/extension-placeholder": "^3.26.1",
    "@tiptap/extension-task-item": "^3.26.1",
    "@tiptap/extension-task-list": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^0.468.0",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "^10.4.20",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.17.0",
    "eslint-config-next": "latest",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
